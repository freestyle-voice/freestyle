{
  "expo": {
    "name": "Freestyle",
    "slug": "freestyle-app",
    "description": "Voice-to-text that works everywhere. Speak naturally, get polished text.",
    "version": "0.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freestyle",
    "userInterfaceStyle": "automatic",
    "owner": "freestyle-voice",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.freestyle.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Freestyle needs microphone access to transcribe your voice.",
        "CFBundleDisplayName": "Freestyle",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["RECORD_AUDIO"],
      "package": "com.freestyle.app",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Freestyle needs microphone access to transcribe your voice."
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      },
      "router": {
        "origin": false
      }
    },
    "updates": {
      "url": ""
    }
  }
}
