# Copy to `.env.local` for local development. `.env.local` is gitignored.

# Point the app at a locally-run Freestyle Cloud (apps/server on :8787).
#
# - iOS Simulator: http://localhost:8787 works.
# - Physical device (Expo Go): use your machine's LAN IP, e.g.
#     EXPO_PUBLIC_CLOUD_URL=http://192.168.1.20:8787
#   (find it with `ipconfig getifaddr en0` on macOS).
#
# Run the local cloud with NODE_ENV=development so the @better-auth/expo
# plugin trusts Expo Go's exp:// deep links. Leave this unset to use
# production (https://service.freestylevoice.com).
EXPO_PUBLIC_CLOUD_URL=http://localhost:8787
