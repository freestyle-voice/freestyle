# Freestyle server environment variables.
#
# These are only needed when running the server standalone (e.g. the Docker
# image via `node dist/startup.js`). When launched from the Electron app the
# server is configured programmatically. Copy this file to `.env` and adjust.
#
# Note: third-party STT/LLM provider API keys (Groq, OpenAI, Freestyle, ...) are
# NOT configured here — they are stored in the SQLite `api_keys` table and
# managed at runtime through the app.

# --- Core server ---------------------------------------------------------------

# Path to the SQLite database file. REQUIRED for the standalone entrypoint.
FREESTYLE_DB_PATH=./freestyle.db

# Port to listen on (default: 4649).
PORT=4649

# Interface to bind to (default: 0.0.0.0 — all interfaces).
HOST=0.0.0.0

# If set, require this value as a bearer token on incoming requests.
# FREESTYLE_AUTH_TOKEN=

# --- Freestyle cloud STT provider ----------------------------------------------

# Base URL of the Freestyle cloud Worker exposing `POST /v1/transcribe`, used by
# the first-party `freestyle` transcription provider (default: http://localhost:8787).
# A `freestyle_cloud_url` row in the `settings` table overrides this.
FREESTYLE_CLOUD_URL=http://localhost:8787

# --- Analytics (PostHog) -------------------------------------------------------

# Set to "production" to enable analytics; anything else is treated as development.
# FREESTYLE_ENV=development

# Set to "1" to opt in to analytics while in development.
# FREESTYLE_ANALYTICS_DEV=0

# Set to "1" to disable all analytics (honored regardless of other settings).
# DO_NOT_TRACK=0

# --- Logging / debug -----------------------------------------------------------

# Set to "1" to log streaming partial transcripts (default: off).
# FREESTYLE_LOG_STREAM_PARTIALS=0

# Set to "0" to disable pipeline latency logging (default: on).
# FREESTYLE_LOG_PIPELINE_LATENCY=1

# --- MLX ASR (Apple Silicon local model) — advanced overrides ------------------

# Override the on-device MLX ASR worker resolution. Normally auto-detected.
# FREESTYLE_MLX_ASR_RELEASE_TAG=
# FREESTYLE_MLX_ASR_WORKER_VERSION=
# FREESTYLE_MLX_ASR_WORKER_URL=
# FREESTYLE_MLX_ASR_WORKER=
# FREESTYLE_MLX_ASR_SCRIPT=

# Python interpreter overrides for the MLX worker (first match wins).
# FREESTYLE_PYTHON=
# PYTHON=

# Hugging Face cache locations used when downloading local models.
# HUGGINGFACE_HUB_CACHE=
# HF_HOME=
