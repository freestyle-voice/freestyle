{
  "name": "@freestyle/plugin-audio-transcription",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Transcribe audio files by dropping them into Freestyle.",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "freestyle": {
    "contributes": {
      "pages": [
        {
          "id": "transcribe-files",
          "title": "Transcribe Files",
          "icon": "FileAudio",
          "entry": "dist/ui/index.html"
        }
      ]
    }
  },
  "scripts": {
    "build": "pkgroll --minify && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json"
  },
  "dependencies": {
    "@freestyle/sdk": "workspace:*"
  },
  "devDependencies": {
    "pkgroll": "^2.27.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
